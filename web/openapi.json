  "paths": {
    "/api/daily": {
      "get": {
        "operationId": "daily_api_daily_get",
        "parameters": [
          {
            "in": "query",
            "name": "days",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "minimum": 1,
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "default": 7,
              "title": "Days"
            }
          },
          {
